datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

enum Role {
  ADMIN
  HR
  MANAGER
  EMPLOYEE
}

enum LeaveStatus {
  PENDING_MANAGER
  PENDING_HR
  APPROVED
  REJECTED
}

enum LeaveType {
  SICK
  CASUAL
  ANNUAL
  UNPAID
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  UNDER_REPAIR
}

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  passwordHash         String
  role                 Role      @default(EMPLOYEE)
  isVerified           Boolean   @default(false)
  verificationToken    String?
  resetToken           String?
  resetTokenExpires    DateTime?
  refreshToken         String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  employee             Employee?

  @@index([email])
}

model Department {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  employees   Employee[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Skill {
  id          String          @id @default(uuid())
  name        String          @unique
  description String?
  employees   EmployeeSkill[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Employee {
  id             String          @id @default(uuid())
  userId         String?         @unique
  user           User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  email          String          @unique
  phone          String?
  departmentId   String?
  department     Department?     @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  hireDate       DateTime        @default(now())
  status         String          @default("ACTIVE") // ACTIVE, LEAVE, TERMINATED
  salary         Decimal         @db.Decimal(12, 2)
  profileImage   String?
  resumePath     String?
  documents      String[]        // Array of document paths
  skills         EmployeeSkill[]
  leaves         Leave[]
  assets         Asset[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([email])
  @@index([departmentId])
}

model EmployeeSkill {
  employeeId       String
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  skillId          String
  skill            Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  proficiencyLevel String   @default("INTERMEDIATE") // BEGINNER, INTERMEDIATE, ADVANCED

  @@id([employeeId, skillId])
}

model Leave {
  id             String      @id @default(uuid())
  employeeId     String
  employee       Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType      LeaveType
  startDate      DateTime
  endDate        DateTime
  reason         String
  status         LeaveStatus @default(PENDING_MANAGER)
  managerId      String?
  managerComment String?
  hrId           String?
  hrComment      String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([employeeId])
  @@index([status])
}

model LeaveBalance {
  id         String    @id @default(uuid())
  employeeId String
  leaveType  LeaveType
  balance    Int       @default(12)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([employeeId, leaveType])
}

model Asset {
  id           String      @id @default(uuid())
  name         String
  type         String      // LAPTOP, MONITOR, MOBILE, etc.
  serialNumber String      @unique
  status       AssetStatus @default(AVAILABLE)
  employeeId   String?
  employee     Employee?   @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  assignedAt   DateTime?
  returnedAt   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([employeeId])
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String   // e.g. "LEAVE_APPROVED", "ASSET_ASSIGNED"
  userId      String
  description String
  timestamp   DateTime @default(now())
}
